<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:text="JSON App"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:text="Pega JSON del portapapeles, valídalo y exporta como archivo."
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnPegar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📋  Pegar desde portapapeles"
        android:textSize="16sp"
        android:backgroundTint="#1976D2"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Esperando contenido del portapapeles..."
        android:textSize="15sp"
        android:textColor="#888888"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#FFFFFF"
            android:hint="El JSON aparecerá aquí..."/>

    </ScrollView>

    <Button
        android:id="@+id/btnExportar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="💾  Exportar como datos.json"
        android:textSize="16sp"
        android:backgroundTint="#388E3C"/>

</LinearLayout>
